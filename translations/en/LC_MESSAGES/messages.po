#: templates/timeline.html.jinja:257
msgid "timeline.tables.pauses.help_title"
msgstr "What the pauses is?"

#: templates/timeline.html.jinja:257
msgid "timeline.tables.pauses.help_text"
msgstr ""
"Pauses are the time while the task is in <strong>On hold</strong>.<br /"
">Graph <code>Actual time</code> shows the physical time between these "
"dates. Graph <code>Only the working time</code> selects from "
"<code>Actual time</code> is from Monday to Friday from 9:00-13:00 and "
"14:00-18:00, excluding holidays.<br /><strong>Note:</strong> the "
"difference of one second between the working time and the actual time is "
"due to the peculiarities of the calculation (rounding to minutes)."

